# REST API 키는 renderer에 노출하지 않고 main 프로세스에서만 사용합니다.
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Kakao JavaScript 키는 지도 SDK 특성상 클라이언트에 노출될 수 있습니다.
# 지도 SDK용으로만 사용하고, 카카오 콘솔에서 허용 범위를 제한하는 것을 권장합니다.
KAKAO_MAP_JS_KEY=your_kakao_javascript_key

# 로컬 렌더러 서버 주소입니다. 카카오 플랫폼에 등록한 값과 동일하게 맞춰 주세요.
HOST=localhost
PORT=3000
